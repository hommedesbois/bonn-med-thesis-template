% Define title format to be plain
\DeclareFieldFormat{title}{#1}             % Regular articles, books
\DeclareFieldFormat[article]{title}{#1}    % Articles
\DeclareFieldFormat[inbook]{title}{#1}     % Book chapters
\DeclareFieldFormat[incollection]{title}{#1}  % Collection entries
\DeclareFieldFormat[inproceedings]{title}{#1} % Conference proceedings
\DeclareFieldFormat[phdthesis]{title}{#1}  % PhD thesis titles without quotes
% Customizing the format for names to appear as "Lastname Initials"
\DeclareNameAlias{sortname}{family-given}
\DeclareNameAlias{default}{family-given}
\DeclareNameFormat{family-given}{%
  \namepartfamily % Outputs the family name
  \ifdefvoid{\namepartgiven}{}{%
    \addspace
    \namepartgiven % Outputs the initial of the given name
  }%
  \ifthenelse{\value{listcount}<\value{liststop}}
    {\addcomma\space} % Adds a comma and space if not the last name
    {.} % Adds a dot after the last name
}

% Plain text for journal titles
\DeclareFieldFormat{journaltitle}{#1}
\DeclareFieldFormat{booktitle}{#1}


% Customizing the bibliography driver for articles
\DeclareBibliographyDriver{article}{%
  \usebibmacro{bibindex}%
  \usebibmacro{begentry}%
  \printnames{author}%
  \setunit{\adddot\space}%
  \printfield{title}%
  \setunit{\addperiod\space}%
  \printfield{journaltitle}%
  \setunit{\addspace}%
  \printfield{year}%
  \setunit{\addsemicolon\space}%
  \printfield{volume}%
  \setunit{\addcolon\space}%
  \printfield{pages}%
  \usebibmacro{finentry}}

% Anpassung des Formats für Bücher
% Format: Author. Title. City: Publisher, year (no period after year)
% Note: biblatex converts 'address' to 'location' internally, so we check location first
\DeclareBibliographyDriver{book}{%
  \printnames{author}%
  \setunit{\adddot\space}%
  \printfield{title}%
  \setunit{\adddot\space}%
  \iflistundef{location}{%
    \iffieldundef{address}{}{%
      \printfield{address}%
      \setunit{\addcolon\space}%
    }%
  }{%
    \printlist{location}%
    \setunit{\addcolon\space}%
  }%
  \printlist{publisher}%
  \setunit{\addcomma\space}%
  \printfield{year}%
  \usebibmacro{finentry}%
}

\DeclareBibliographyDriver{incollection}{%
  \printnames{author}%
  \setunit{\adddot\space}%
  \printfield{title}%
  \setunit{\adddot\space}%
  \printtext{in: }%
  \printnames{editor}%
  \setunit{\addspace}%
  \printtext{Hrsg\adddot}%
  \setunit{\addspace}%
  \printfield{booktitle}%
  \setunit{\adddot\space}%
  \printlist{location}%
  \setunit{\addcolon\space}%
  \printlist{publisher}%
  \setunit{\addcomma\space}%
  \printfield{year}%
  \setunit{\addcolon\space}%
  \printfield{pages}%
  \finentry
}

