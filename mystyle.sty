% Kapitelüberschriften: 14pt und fett, ohne "Kapitel", Format: 1. Einleitung
\RequirePackage{titlesec}
\titleformat{\chapter}[hang]
  {\normalfont\fontsize{14}{16.8}\bfseries}{\thechapter.}{1em}{}
\titlespacing*{\chapter}{0pt}{0pt}{20pt}
% Ensure TOC shows chapter numbers with period
\makeatletter
% Modify how chapters are written to TOC to include period
\let\old@chapter\@chapter
\def\@chapter[#1]#2{%
  \ifnum \c@secnumdepth >\m@ne
    \refstepcounter{chapter}%
    \typeout{\@chapapp\space\thechapter.}%
    \def\@tempa{#1}%
    \ifx\@tempa\@empty
      \addtocontents{toc}{\protect\contentsline{chapter}{\protect\numberline{\thechapter.~}#2}{\thepage}{chapter.\thechapter}}%
      \chaptermark{#2}%
    \else
      \addtocontents{toc}{\protect\contentsline{chapter}{\protect\numberline{\thechapter.~}#1}{\thepage}{chapter.\thechapter}}%
      \chaptermark{#1}%
    \fi
  \fi
  \addtocontents{lof}{\protect\addvspace{10\p@}}%
  \addtocontents{lot}{\protect\addvspace{10\p@}}%
  \if@twocolumn
    \@topnewpage[\@makechapterhead{#2}]%
  \else
    \@makechapterhead{#2}%
    \@afterheading
  \fi}
\makeatother

% Section-Überschriften: 12pt, nicht fett, wie Text (1.1., 1.2., etc.)
\titleformat{\section}
